        )}
        {person && (
          <div style={styles.previewBox}>
            <div style={styles.previewLine}>
              <strong>{crewLabel}</strong> → {person.name} wird bei{" "}
              <strong>{location.trim() ? location.trim() : "…"}</strong>{" "}
