          dateKey={showAbsenceQuick.dateKey}
          onClose={() => setShowAbsenceQuick(null)}
          onSave={async (a) => {
            await saveAbsences([...absences, a]);
            setShowAbsenceQuick(null);
          }}
        />
      )}

      {showNoteModal && (
        <NoteModal
          data={showNoteModal}
          onClose={() => setShowNoteModal(null)}
          onSave={async (n) => {
            const exists = notes.find((x) => x.id === n.id);
            const next = exists ? notes.map((x) => (x.id === n.id ? n : x)) : [...notes, n];
            await saveNotes(next);
            setShowNoteModal(null);
          }}
          onDelete={async (id) => {
            await saveNotes(notes.filter((x) => x.id !== id));
            setShowNoteModal(null);
          }}
        />
      )}

      {showMemberModal && (
        <MemberModal
          member={null}
          existingCount={members.length}
          onClose={() => setShowMemberModal(false)}
          onSave={async (m) => {
            await saveMembers([...members, m]);
            setShowMemberModal(false);
          }}
        />
      )}

      {showPersonAkte && (
        <PersonAkte
          member={membersById[showPersonAkte.id] || showPersonAkte}
          events={events}
          absences={absences.filter((a) => a.memberId === showPersonAkte.id)}
          onClose={() => setShowPersonAkte(null)}
          onSaveMember={async (m) => {
            await saveMembers(members.map((x) => (x.id === m.id ? m : x)));
