          <Plus size={16} /> Person hinzufügen
        </button>
      </div>

      <TeamGroup
        label="One Gem Crew"
        count={fixed.length}
        people={fixed}
        upcomingCount={upcomingCount}
        activeAbsence={activeAbsence}
        onOpenPerson={onOpenPerson}
      />
      <TeamGroup
        label="Beguna Crew"
        count={freelance.length}
        people={freelance}
        upcomingCount={upcomingCount}
        activeAbsence={activeAbsence}
        onOpenPerson={onOpenPerson}
      />
    </div>
  );
}

