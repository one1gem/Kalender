          }}
          onDeleteMember={async (id) => {
            await saveMembers(members.filter((m) => m.id !== id));
            await saveEvents(events.map((e) => ({ ...e, assignees: e.assignees.filter((a) => a !== id) })));
            await saveAbsences(absences.filter((a) => a.memberId !== id));
            setShowPersonAkte(null);
          }}
          onAddAbsence={async (absence) => {
            await saveAbsences([...absences, absence]);
          }}
          onDeleteAbsence={async (id) => {
            await saveAbsences(absences.filter((a) => a.id !== id));
          }}
        />
      )}

      {showShare && (
        <ShareModal title={showShare.title} text={showShare.text} onClose={() => setShowShare(null)} />
      )}
    </div>
  );
}

