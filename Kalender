  const saveEvents = useCallback(async (next) => {
    setEvents(next);
    try {
      await window.storage.set("calendar-events", JSON.stringify(next), true);
    } catch {
      setError("Speichern fehlgeschlagen. Bitte erneut versuchen.");
    }
  }, []);

  const saveAbsences = useCallback(async (next) => {
    setAbsences(next);
    try {
      await window.storage.set("absences", JSON.stringify(next), true);
    } catch {
      setError("Speichern fehlgeschlagen. Bitte erneut versuchen.");
    }
  }, []);

  const saveNotes = useCallback(async (next) => {
    setNotes(next);
    try {
      await window.storage.set("notes", JSON.stringify(next), true);
    } catch {
      setError("Speichern fehlgeschlagen. Bitte erneut versuchen.");
    }
  }, []);

