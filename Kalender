      try {
        let m = [];
        try {
          const r = await window.storage.get("team-members", true);
          m = r ? JSON.parse(r.value) : [];
        } catch { m = []; }
        let e = [];
        try {
          const r = await window.storage.get("calendar-events", true);
          e = r ? JSON.parse(r.value) : [];
        } catch { e = []; }
        let a = [];
        try {
          const r = await window.storage.get("absences", true);
          a = r ? JSON.parse(r.value) : [];
        } catch { a = []; }
        let n = [];
        try {
          const r = await window.storage.get("notes", true);
          n = r ? JSON.parse(r.value) : [];
        } catch { n = []; }
        setMembers(m);
        setEvents(e);
        setAbsences(a);
        setNotes(n);
      } catch (err) {
        setError("Daten konnten nicht geladen werden.");
        setMembers([]);
        setEvents([]);
        setAbsences([]);
        setNotes([]);
      }
    })();
  }, []);

  const saveMembers = useCallback(async (next) => {
    setMembers(next);
    try {
      await window.storage.set("team-members", JSON.stringify(next), true);
    } catch {
      setError("Speichern fehlgeschlagen. Bitte erneut versuchen.");
